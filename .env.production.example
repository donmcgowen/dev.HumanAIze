# Copy this file to .env.production and fill in real values.
# .env.production is gitignored — never commit it.

# ── Azure AD B2C ──────────────────────────────────────────────────────────────
# Tenant name (the part before .onmicrosoft.com)
AZURE_AD_B2C_TENANT=humanaize
# App registration → client ID (Application ID)
AZURE_AD_B2C_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# App registration → Certificates & Secrets → client secret value
AZURE_AD_B2C_CLIENT_SECRET=your-client-secret-value
# User flow name (Identity Experience Framework or built-in user flow)
AZURE_AD_B2C_POLICY=B2C_1_signupsignin

# ── Azure AD B2C (client-side / Vite build-time) ──────────────────────────────
# These are embedded into the browser bundle at build time.
# Must match the server-side values above.
VITE_AZURE_B2C_TENANT_NAME=humanaize
VITE_AZURE_B2C_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_AZURE_B2C_POLICY_NAME=B2C_1_signupsignin

# ── Session ───────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-hex-secret

# ── Azure SQL Database ────────────────────────────────────────────────────────
AZURE_SQL_CONNECTION_STRING=Server=tcp:yourserver.database.windows.net,1433;Initial Catalog=humanaize;Persist Security Info=False;User ID=youradmin;Password=yourpassword;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# ── Azure Blob Storage (progress photos) ─────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_STORAGE_CONTAINER_NAME=humanaize-photos
AZURE_STORAGE_ACCOUNT_KEY=your-base64-storage-key==

# ── LLM API ───────────────────────────────────────────────────────────────────
# Option A — OpenAI:  BUILT_IN_FORGE_API_URL=https://api.openai.com
# Option B — Azure OpenAI (full URL including deployment + api-version):
#   BUILT_IN_FORGE_API_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-02-01
BUILT_IN_FORGE_API_URL=https://api.openai.com
BUILT_IN_FORGE_API_KEY=sk-your-openai-or-azure-openai-key
LLM_MODEL=gpt-4o-mini

# ── App (optional) ────────────────────────────────────────────────────────────
# Your own openId (oid from B2C) — used to mark your account as owner/admin
OWNER_OPEN_ID=your-b2c-object-id
